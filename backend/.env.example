# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
JWT_SECRET=your_jwt_secret

# ── Application ───────────────────────────────────────────
ENVIRONMENT=production
API_TITLE=LoyalCup API
API_VERSION=1.0.0
FRONTEND_URL=https://loyalcupapp.com

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://loyalcupapp.com"]

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ── Square (customer payments + POS) ──────────────────────
SQUARE_ENV=production
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
SQUARE_CALLBACK_URL=https://api.your-backend.com/api/v1/pos/square/callback
SQUARE_WEBHOOK_SIGNATURE_KEY=

# ── Stripe (shop owner subscriptions) ─────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ── Sentry ────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Email (SendGrid) ──────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@loyalcup.com

# ── Redis (cache + rate limit store) ──────────────────────
REDIS_URL=redis://localhost:6379