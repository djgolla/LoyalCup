"""
Square Webhook Handler
Receives order state change events from Square and syncs status into LoyalCup orders.

Setup required:
  1. In Square Developer Dashboard → Webhooks → Add endpoint:
     URL: https://loyalcup-production.up.railway.app/api/v1/pos/square/webhook
     Events: order.updated, order.created
  2. Copy the webhook signature key → add to Railway as SQUARE_WEBHOOK_SIGNATURE_KEY

How it works:
  - Customer places order in LoyalCup → order pushed to Square POS (reference_id = loyalcup order id)
  - Barista updates order on Square register/KDS
  - Square fires webhook → we match by reference_id → update LoyalCup order status
  - Supabase realtime pushes update to customer's phone instantly
"""
import hashlib
import hmac
import json
import logging
import os
from fastapi import APIRouter, Request, HTTPException

from app.database import get_supabase

router = APIRouter()
logger = logging.getLogger(__name__)

SQUARE_WEBHOOK_SIG_KEY = os.getenv("SQUARE_WEBHOOK_SIGNATURE_KEY", "")

# Square order state → LoyalCup status
SQUARE_STATE_MAP = {
    "OPEN":        "accepted",
    "IN_PROGRESS": "preparing",
    "COMPLETED":   "picked_up",
    "CANCELED":    "cancelled",
}


def _verify_square_signature(body: bytes, signature: str, url: str) -> bool:
    """
    Square HMAC-SHA256 signature verification.
    https://developer.squareup.com/docs/webhooks/step3validate
    """
    if not SQUARE_WEBHOOK_SIG_KEY:
        logger.warning("[SquareWebhook] No signature key set — skipping verification (dev mode)")
        return True
    combined = url + body.decode("utf-8")
    expected = hmac.new(
        SQUARE_WEBHOOK_SIG_KEY.encode("utf-8"),
        combined.encode("utf-8"),
        hashlib.sha256,
    ).digest()
    import base64
    expected_b64 = base64.b64encode(expected).decode("utf-8")
    return hmac.compare_digest(expected_b64, signature or "")


@router.post("/api/v1/pos/square/webhook")
async def square_webhook(request: Request):
    body = await request.body()
    signature = request.headers.get("x-square-hmacsha256-signature", "")
    url = str(request.url)

    if not _verify_square_signature(body, signature, url):
        logger.warning("[SquareWebhook] Signature mismatch — rejecting")
        raise HTTPException(status_code=400, detail="Invalid signature")

    try:
        payload = json.loads(body)
    except Exception:
        raise HTTPException(status_code=400, detail="Invalid JSON")

    event_type = payload.get("type", "")
    logger.info(f"[SquareWebhook] Event: {event_type}")

    # Only care about order updates
    if event_type not in ("order.updated", "order.created", "order.fulfillment.updated"):
        return {"received": True, "action": "ignored"}

    data = payload.get("data", {}).get("object", {})
    order_obj = data.get("order_updated") or data.get("order") or data.get("fulfillment", {}).get("order") or {}

    # For fulfillment events, extract nested order
    if event_type == "order.fulfillment.updated":
        order_obj = data.get("fulfillment", {})
        new_state = order_obj.get("state")
        reference_id = order_obj.get("order_id")  # Square order ID, not reference_id
        # Look up by square_order_id in metadata
        await _sync_by_square_order_id(reference_id, new_state)
        return {"received": True}

    state = order_obj.get("state")
    reference_id = order_obj.get("reference_id")  # This is our loyalcup order ID

    if not reference_id or not state:
        logger.debug(f"[SquareWebhook] No reference_id or state in payload — skipping")
        return {"received": True, "action": "no_reference"}

    loyalcup_status = SQUARE_STATE_MAP.get(state)
    if not loyalcup_status:
        logger.debug(f"[SquareWebhook] Unmapped Square state: {state}")
        return {"received": True, "action": "unmapped_state"}

    await _update_order_status(reference_id, loyalcup_status, source="square_webhook")
    return {"received": True}


async def _sync_by_square_order_id(square_order_id: str, state: str):
    """Look up LoyalCup order by metadata.square_order_id and sync status."""
    if not square_order_id or not state:
        return
    loyalcup_status = SQUARE_STATE_MAP.get(state)
    if not loyalcup_status:
        return
    try:
        db = get_supabase()
        # Supabase JSONB query: metadata->>'square_order_id' = square_order_id
        resp = (
            db.get_service_client()
            .table("orders")
            .select("id, status")
            .eq("metadata->>square_order_id", square_order_id)
            .limit(1)
            .execute()
        )
        if resp.data:
            order = resp.data[0]
            await _update_order_status(order["id"], loyalcup_status, source="square_fulfillment_webhook")
    except Exception as e:
        logger.exception(f"[SquareWebhook] _sync_by_square_order_id failed: {e}")


async def _update_order_status(order_id: str, new_status: str, source: str = "webhook"):
    """
    Update order status in Supabase — but only if it's a valid forward transition.
    Never go backwards (e.g. don't set accepted if already preparing).
    """
    STATUS_ORDER = ["pending", "accepted", "preparing", "ready", "picked_up", "completed", "cancelled"]

    try:
        db = get_supabase()
        resp = (
            db.get_service_client()
            .table("orders")
            .select("id, status")
            .eq("id", order_id)
            .limit(1)
            .execute()
        )

        if not resp.data:
            logger.warning(f"[SquareWebhook] Order {order_id} not found")
            return

        order = resp.data[0]
        current = order["status"]

        # Don't go backwards or touch terminal states
        if current in ("completed", "cancelled"):
            logger.debug(f"[SquareWebhook] Order {order_id} already terminal ({current}) — skipping")
            return

        current_idx = STATUS_ORDER.index(current) if current in STATUS_ORDER else -1
        new_idx = STATUS_ORDER.index(new_status) if new_status in STATUS_ORDER else -1

        if new_idx <= current_idx:
            logger.debug(f"[SquareWebhook] Skipping backward transition {current} → {new_status} for order {order_id}")
            return

        db.get_service_client().table("orders").update({
            "status": new_status,
            "updated_at": __import__("datetime").datetime.utcnow().isoformat(),
        }).eq("id", order_id).execute()

        logger.info(f"[SquareWebhook] ({source}) Order {order_id}: {current} → {new_status} ✓")

    except Exception as e:
        logger.exception(f"[SquareWebhook] Failed to update order {order_id}: {e}")